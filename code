import numpy as np
import pandas as pd
import os
from pathlib import Path

# Load decision matrix
current_dir = Path(__file__).parent
data = pd.read_csv(current_dir.parent / "data" / "decision_matrix.csv")

models = data.iloc[:, 0]
criteria = data.iloc[:, 1:]

# Weights
weights = np.array([0.30, 0.25, 0.15, 0.15, 0.15])

# Normalize the decision matrix
normalized = criteria / np.sqrt((criteria ** 2).sum())

# Weighted normalized matrix
weighted_normalized = normalized * weights

# Identify ideal best and worst
ideal_best = np.array([
    weighted_normalized.iloc[:, 0].max(),
    weighted_normalized.iloc[:, 1].max(),
    weighted_normalized.iloc[:, 2].min(),
    weighted_normalized.iloc[:, 3].min(),
    weighted_normalized.iloc[:, 4].min()
])

ideal_worst = np.array([
    weighted_normalized.iloc[:, 0].min(),
    weighted_normalized.iloc[:, 1].min(),
    weighted_normalized.iloc[:, 2].max(),
    weighted_normalized.iloc[:, 3].max(),
    weighted_normalized.iloc[:, 4].max()
])

# Calculate distances
distance_best = np.sqrt(((weighted_normalized - ideal_best) ** 2).sum(axis=1))
distance_worst = np.sqrt(((weighted_normalized - ideal_worst) ** 2).sum(axis=1))

# TOPSIS score
topsis_score = distance_worst / (distance_best + distance_worst)

# Results
result = pd.DataFrame({
    "Model": models,
    "TOPSIS_Score": topsis_score
})

result["Rank"] = result["TOPSIS_Score"].rank(ascending=False)
result = result.sort_values("Rank")

# Save results
result.to_csv(current_dir.parent / "results" / "topsis_scores.csv", index=False)

print("TOPSIS ranking completed successfully.")
print(result)
